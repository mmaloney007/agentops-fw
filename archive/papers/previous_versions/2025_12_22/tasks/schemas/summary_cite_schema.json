{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/summary_cite_schema.json",
  "title": "CitedSummary",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "bullets"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "bullets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "cites"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 5,
            "maxLength": 280
          },
          "cites": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "type": "string",
              "pattern": "^s[0-9]+$"
            }
          }
        }
      }
    }
  }
}
